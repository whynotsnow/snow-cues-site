---
import '../styles/site.css';

const appUrl = 'https://cues.whynotsnow.com/';

interface FeatureItem {
  icon: string;
  title: string;
  text: string;
}

const highlights: FeatureItem[] = [
  {
    icon: '🖥',
    title: '本地优先',
    text: 'Snow Cues 在浏览器中运行，不提供账号系统、后端同步或云端恢复服务。',
  },
  {
    icon: '🔐',
    title: '双秘密模型',
    text: '空间主密码建立当前会话，单条密码的关键密钥参与生成和解密。',
  },
  {
    icon: '☁️',
    title: '静态部署',
    text: '应用和文档都可以构建为静态产物，适合 GitHub Pages 或 Cloudflare Pages。',
  },
];

const flows = ['创建空间', '设置空间主密码', '初始化规则链', '创建并加密保存密码'];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Google Fonts: Inter + Fira Code -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&family=Inter:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <meta
      name="description"
      content="Snow Cues 是一个本地优先的密码派生与加密存储系统。"
    />
    <title>Snow Cues | 本地优先密码派生与加密存储</title>
  </head>
  <body>
    <main>
      <!-- ── Navbar ── -->
      <header class="site-nav" id="site-nav" aria-label="站点导航">
        <a class="brand" href="/">
          <span class="brand-mark">S</span>
          <span>Snow Cues</span>
        </a>
        <nav class="nav-links" aria-label="主要链接">
          <a href="/docs/">用户文档</a>
          <a href="/docs/user/security-and-privacy/">安全与隐私</a>
          <a href={appUrl}>打开应用</a>
        </nav>
        <button class="theme-toggle" id="theme-toggle" aria-label="切换主题" title="切换深浅主题">
          <span id="theme-icon-light" style="display:none;">☀️</span>
          <span id="theme-icon-dark">🌙</span>
        </button>
      </header>

      <div class="site-shell">

        <!-- ── Hero ── -->
        <section class="hero-section">
          <div class="hero-copy reveal">
            <span class="badge">Local-first password derivation</span>
            <h1 class="display-xl">只在本地运行的密码派生与加密存储工具。</h1>
            <p class="hero-lead">
              Snow Cues 面向愿意自己掌控秘密材料的用户：不保存空间主密码，不保存关键密钥，
              只在浏览器本地加密保存密码输出和必要的管理元数据。
            </p>
            <div class="hero-actions">
              <a class="button primary pill" href="/docs/user/quick-start/">阅读快速开始</a>
              <a class="button outline pill" href={appUrl}>打开应用</a>
            </div>
          </div>

          <div class="product-panel reveal reveal-d2" aria-label="Snow Cues 工作流预览">
            <div class="panel-topbar">
              <span></span>
              <span></span>
              <span></span>
            </div>
            <div class="panel-body">
              <p class="panel-kicker">核心工作流</p>
              <ol class="flow-list">
                {flows.map((flow, index) => (
                  <li>
                    <span>{index + 1}</span>
                    <strong>{flow}</strong>
                  </li>
                ))}
              </ol>
            </div>
          </div>
        </section>

        <!-- ── Features ── -->
        <section class="section-y">
          <div class="section-heading reveal">
            <span class="eyebrow">Why Snow Cues</span>
            <h2 class="display-md">清楚边界，比神奇承诺更重要。</h2>
          </div>
          <div class="feature-grid">
            {highlights.map((item, index) => (
              <article class={`feature-card reveal reveal-d${index + 1}`}>
                <div class="feature-icon">{item.icon}</div>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))}
          </div>
        </section>

        <!-- ── Callout ── -->
        <section class="section-y">
          <div class="callout reveal">
            <div>
              <span class="eyebrow">Start here</span>
              <h2>第一次使用前，建议先读完安全边界。</h2>
              <p>
                Snow Cues 不能替你恢复忘记的空间主密码或关键密钥。文档会明确说明系统保存什么、
                不保存什么，以及换设备或清理浏览器数据前需要自己备份什么。
              </p>
            </div>
            <a class="button primary pill" href="/docs/user/security-and-privacy/">查看安全边界</a>
          </div>
        </section>

        <!-- ── CTA ── -->
        <section class="section-y">
          <div class="cta-section reveal">
            <div class="cta-grid-overlay"></div>
            <div class="cta-content">
              <h2>开始掌控你的秘密材料</h2>
              <p>无需注册、无需服务器，打开浏览器即可使用。</p>
              <div class="cta-actions">
                <a class="button primary pill" href={appUrl}>打开应用</a>
                <a class="button outline pill" href="/docs/user/quick-start/">阅读文档</a>
              </div>
            </div>
          </div>
        </section>

        <!-- ── Footer ── -->
        <footer class="site-footer">
          <span>&copy; 2025 Snow Cues</span>
          <span>
            <a href="/docs/">文档</a> · <a href="/docs/user/security-and-privacy/">安全</a> · <a href={appUrl}>应用</a>
          </span>
        </footer>

      </div>
    </main>

    <script>
      /* ── Navbar scroll trigger ── */
      (function() {
        const nav = document.getElementById('site-nav');
        const onScroll = () => {
          if (nav) nav.classList.toggle('scrolled', window.scrollY > 20);
        };
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });

        /* ── Theme toggle ── */
        const btn = document.getElementById('theme-toggle');
        const iconL = document.getElementById('theme-icon-light');
        const iconD = document.getElementById('theme-icon-dark');

        function applyTheme(theme) {
          document.documentElement.setAttribute('data-theme', theme);
          try { localStorage.setItem('sc-theme', theme); } catch(e) {}
          if (iconL) iconL.style.display = theme === 'dark' ? 'inline' : 'none';
          if (iconD) iconD.style.display = theme === 'light' ? 'inline' : 'none';
        }

        var saved = null;
        try { saved = localStorage.getItem('sc-theme'); } catch(e) {}
        if (saved === 'light' || saved === 'dark') {
          applyTheme(saved);
        } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          applyTheme('dark');
        }

        if (btn) {
          btn.addEventListener('click', function() {
            var current = document.documentElement.getAttribute('data-theme');
            applyTheme(current === 'dark' ? 'light' : 'dark');
          });
        }

        /* ── Scroll reveal ── */
        var observer = new IntersectionObserver(
          function(entries) {
            entries.forEach(function(entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('in-view');
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
        );
        document.querySelectorAll('.reveal').forEach(function(el) {
          observer.observe(el);
        });
      })();
    </script>
  </body>
</html>
